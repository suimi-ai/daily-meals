<view class="container">
  <view wx:if="{{loading}}" class="loading">加载中...</view>

  <view wx:if="{{!loading && menu}}">
    <!-- 菜单列表 -->
    <view class="card">
      <view class="title">今日菜单</view>
      <view class="subtitle">点击选择要制作的菜品</view>
    </view>

    <view 
      wx:for="{{menu.dishes}}" 
      wx:key="name"
      class="dish-card {{selectedDishes.some(d => d.name === item.name) ? 'selected' : ''}}"
      data-dish="{{item.name}}"
      bindtap="toggleDish"
    >
      <view class="dish-header">
        <view class="dish-name">{{item.name}}</view>
        <view class="dish-check" wx:if="{{selectedDishes.some(d => d.name === item.name)}}">
          ✓
        </view>
      </view>
      
      <view class="dish-desc">{{item.description}}</view>
      
      <view class="dish-meta">
        <view class="meta-item">
          <text class="icon">⏱</text>
          <text>{{item.time}}</text>
        </view>
        <view class="meta-item">
          <text class="icon">📊</text>
          <text>难度 {{item.difficulty}}/5</text>
        </view>
      </view>

      <view class="dish-actions">
        <view 
          class="action-btn" 
          catchtap="viewRecipe"
          data-dish="{{item.name}}"
        >
          查看菜谱
        </view>
      </view>
    </view>

    <!-- 营养信息 -->
    <view class="card" wx:if="{{menu.nutrition}}">
      <view class="title">营养信息</view>
      <view class="nutrition-grid">
        <view class="nutrition-item">
          <view class="value">{{menu.nutrition.calories}}</view>
          <view class="label">卡路里</view>
        </view>
        <view class="nutrition-item">
          <view class="value">{{menu.nutrition.protein}}g</view>
          <view class="label">蛋白质</view>
        </view>
        <view class="nutrition-item">
          <view class="value">{{menu.nutrition.carbs}}g</view>
          <view class="label">碳水</view>
        </view>
        <view class="nutrition-item">
          <view class="value">{{menu.nutrition.fat}}g</view>
          <view class="label">脂肪</view>
        </view>
      </view>
    </view>

    <!-- 生成购物清单按钮 -->
    <view 
      class="btn-primary" 
      bindtap="generateShoppingList"
      wx:if="{{selectedDishes.length > 0}}"
    >
      生成购物清单 ({{selectedDishes.length}}道菜)
    </view>
  </view>
</view>
