.summary {
  display: flex;
  justify-content: space-around;
  text-align: center;
}

.summary-item .value {
  font-size: 48rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.summary-item .value.need {
  color: #FF6B6B;
}

.summary-item .value.have {
  color: #52c41a;
}

.summary-item .label {
  font-size: 24rpx;
  color: #999;
}

.category-section {
  margin-bottom: 30rpx;
}

.category-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
  padding-left: 8rpx;
}

.ingredient-card {
  background-color: white;
  padding: 20rpx;
  border-radius: 12rpx;
  margin-bottom: 12rpx;
  position: relative;
}

.ingredient-card.purchased {
  opacity: 0.5;
}

.ingredient-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.ingredient-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
}

.ingredient-amount {
  font-size: 28rpx;
  color: #666;
}

.ingredient-status {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.status-badge {
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
}

.status-badge.need {
  background-color: #fff1f0;
  color: #FF6B6B;
}

.status-badge.have {
  background-color: #f6ffed;
  color: #52c41a;
}

.check-icon {
  width: 32rpx;
  height: 32rpx;
  background-color: #52c41a;
  color: white;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
}

.ingredient-tip {
  font-size: 22rpx;
  color: #999;
  line-height: 1.4;
}
