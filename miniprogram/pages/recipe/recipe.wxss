.recipe-header {
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E8E 100%);
  color: white;
  padding: 40rpx 30rpx;
  border-radius: 0 0 30rpx 30rpx;
  margin-bottom: 20rpx;
}

.recipe-title {
  font-size: 40rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.recipe-desc {
  font-size: 28rpx;
  opacity: 0.9;
  margin-bottom: 20rpx;
}

.recipe-meta {
  display: flex;
  gap: 30rpx;
}

.meta-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 26rpx;
  opacity: 0.9;
}

.ingredients-list {
  margin-top: 16rpx;
}

.ingredient-item {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.ingredient-item:last-child {
  border-bottom: none;
}

.ingredient-name {
  font-size: 28rpx;
  color: #333;
}

.ingredient-amount {
  font-size: 28rpx;
  color: #999;
}

.step-indicator {
  display: flex;
  gap: 16rpx;
  margin: 20rpx 0;
  overflow-x: auto;
  padding: 10rpx 0;
}

.step-dot {
  min-width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background-color: #f0f0f0;
  color: #999;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 500;
  transition: all 0.3s;
}

.step-dot.active {
  background-color: #FF6B6B;
  color: white;
}

.step-detail {
  margin: 30rpx 0;
}

.step-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}

.step-time {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 26rpx;
  color: #999;
  margin-bottom: 20rpx;
}

.step-description {
  font-size: 30rpx;
  line-height: 1.8;
  color: #666;
  margin-bottom: 20rpx;
}

.step-tips {
  background-color: #fff9e6;
  padding: 20rpx;
  border-radius: 12rpx;
  border-left: 6rpx solid #FFB800;
}

.tips-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #FFB800;
  margin-bottom: 8rpx;
}

.tips-content {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}

.step-navigation {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 30rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.nav-btn {
  padding: 16rpx 32rpx;
  background-color: #FF6B6B;
  color: white;
  border-radius: 40rpx;
  font-size: 28rpx;
}

.nav-btn.disabled {
  background-color: #e0e0e0;
  color: #999;
  pointer-events: none;
}

.step-counter {
  font-size: 28rpx;
  color: #999;
}

.nutrition-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
  margin-top: 20rpx;
}

.nutrition-item {
  text-align: center;
}

.nutrition-item .value {
  font-size: 32rpx;
  font-weight: 600;
  color: #FF6B6B;
  margin-bottom: 8rpx;
}

.nutrition-item .label {
  font-size: 24rpx;
  color: #999;
}

.tips-list {
  margin-top: 16rpx;
}

.tip-item {
  display: flex;
  gap: 12rpx;
  padding: 12rpx 0;
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
}

.tip-item .bullet {
  color: #FF6B6B;
  font-weight: 600;
}
