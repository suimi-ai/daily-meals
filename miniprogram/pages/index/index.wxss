.container {
  min-height: 100vh;
  background: linear-gradient(to bottom, #FF6B6B 0%, #FF6B6B 30%, #f5f5f5 30%);
}

.header {
  padding: 60rpx 40rpx 80rpx;
  color: white;
  text-align: center;
}

.greeting {
  font-size: 48rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.subtitle {
  font-size: 28rpx;
  opacity: 0.9;
}

.meal-types {
  display: flex;
  gap: 20rpx;
  margin-top: 20rpx;
}

.meal-type {
  flex: 1;
  padding: 24rpx;
  text-align: center;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  background-color: white;
  font-size: 32rpx;
  transition: all 0.3s;
}

.meal-type.active {
  background-color: #FF6B6B;
  color: white;
  border-color: #FF6B6B;
}

.servings-input {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-top: 20rpx;
}

.servings-input input {
  flex: 1;
  padding: 20rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  font-size: 32rpx;
  text-align: center;
}

.btn-primary {
  margin: 40rpx 0;
}

.loading-btn {
  opacity: 0.6;
  pointer-events: none;
}

.quick-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 40rpx;
}

.action-item {
  flex: 1;
  background-color: white;
  padding: 30rpx 20rpx;
  border-radius: 12rpx;
  text-align: center;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.action-item .icon {
  font-size: 48rpx;
  display: block;
  margin-bottom: 12rpx;
}

.action-item text:last-child {
  font-size: 24rpx;
  color: #666;
}
